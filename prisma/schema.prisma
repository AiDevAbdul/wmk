generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin user for authentication
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin") // admin, editor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// Service management
model Service {
  id          String   @id @default(cuid())
  nameEn      String
  nameAr      String
  slug        String   @unique
  description String
  descriptionAr String
  faq         String   @default("[]") // JSON string: Array of {question, answer}
  brands      String   @default("[]") // JSON string: Array of brand slugs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

// Blog posts
model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String
  excerpt       String
  category      String   // ECM Tips, Hybrid Battery, Maintenance, News
  featuredImage String?
  author        String   @default("WMK Team")
  published     Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("blog_posts")
}

// Contact form submissions
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String
  carBrand  String
  service   String
  message   String
  status    String   @default("new") // new, read, replied, archived
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}

// Site-wide settings (single row, id is always "1")
model SiteSettings {
  id        String   @id @default("1")
  phone     String   @default("+971 55 476 2284")
  whatsapp  String   @default("https://wa.me/971554762284")
  email     String   @default("info@wmk.ae")
  address   String   @default("18 Street, Ras Al Khor Industrial Area 2, Dubai, UAE")
  addressAr String   @default("شارع 18، منطقة راس الخور الصناعية 2، دبي، الإمارات")
  hours     String   @default("Saturday–Thursday: 08:00–22:00 (Closed Friday)")
  latitude  String   @default("25.1972")
  longitude String   @default("55.3586")
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Analytics events
model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   // page_view, phone_click, whatsapp_click, form_submit
  page      String
  userId    String?
  metadata  String?  // JSON string
  timestamp DateTime @default(now())

  @@map("analytics_events")
}
